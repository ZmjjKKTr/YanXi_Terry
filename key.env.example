# 言犀 环境变量 — 复制为 key.env 并填入实际值
# cp key.env.example key.env

# LLM 后端: zhipu（智谱云端）或 ollama（本地部署）
LLM_BACKEND=zhipu

# 智谱 API Key（LLM_BACKEND=zhipu 时必填）
# 获取地址: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=你的API_KEY
ZHIPU_MODEL=glm-4-flash
ZHIPU_TEMPERATURE=0.3

# Ollama 配置（LLM_BACKEND=ollama 时使用）
OLLAMA_MODEL=qwen:7b
OLLAMA_BASE_URL=http://localhost:11434

# ASR 引擎: vosk（离线）或 whisper（云端）
ASR_ENGINE=vosk

# 调试模式
YANXI_DEBUG=false

# API 服务
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=
