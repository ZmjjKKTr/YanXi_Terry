# 言犀 环境变量模板 — 复制为 key.env 并填入实际值

# LLM 后端: zhipu（智谱云端）或 ollama（本地部署）
LLM_BACKEND=zhipu

# 智谱 API Key（LLM_BACKEND=zhipu 时必填）
ZHIPUAI_API_KEY=e73f8c46c6464162832306f6ac1a3649.MaQWY75Pi4Z8r7XQ
ZHIPU_MODEL=glm-5.1
ZHIPU_TEMPERATURE=0.3

# Ollama 配置（LLM_BACKEND=ollama 时使用）
OLLAMA_MODEL=qwen:7b
OLLAMA_BASE_URL=http://localhost:11434

# ASR 引擎: vosk（离线）或 whisper（云端）
ASR_ENGINE=vosk

# 调试模式
YANXI_DEBUG=false
